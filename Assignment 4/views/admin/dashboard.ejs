<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Limelight</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f3efe5;
            color: #1a1a1a;
        }

        .admin-layout {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 240px;
            background: #1a1a1a;
            color: #fff;
            padding: 28px 22px;
        }

        .brand {
            font-size: 28px;
            font-weight: bold;
            letter-spacing: 3px;
            color: #b38d36;
            margin-bottom: 30px;
        }

        .sidebar a {
            display: block;
            color: #fff;
            text-decoration: none;
            padding: 12px 14px;
            border-radius: 6px;
            margin-bottom: 10px;
        }

        .sidebar a.active,
        .sidebar a:hover {
            background: #b38d36;
            color: #1a1a1a;
            font-weight: bold;
        }

        .home-link {
            background: #efeae7;
            color: #1a1a1a;
        }

        .content {
            flex: 1;
            padding: 30px;
            background: #fff;
        }

        .page-title {
            margin: 0 0 18px;
            font-size: 30px;
            letter-spacing: 1px;
        }

        .panel {
            border: 1px solid #e4dccd;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: #fff;
        }

        th, td {
            padding: 14px 12px;
            text-align: left;
            border-bottom: 1px solid #eee7dc;
            vertical-align: middle;
            font-size: 14px;
        }

        th {
            background: #f8f4ec;
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.6px;
        }

        .thumb {
            width: 54px;
            height: 72px;
            object-fit: cover;
            border-radius: 6px;
            border: 1px solid #ddd;
        }

        .actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .btn {
            display: inline-block;
            padding: 9px 14px;
            border-radius: 6px;
            text-decoration: none;
            border: none;
            cursor: pointer;
            font-weight: bold;
            font-size: 13px;
        }

        .btn-gold {
            background: #b38d36;
            color: #1a1a1a;
        }

        .btn-dark {
            background: #1a1a1a;
            color: #fff;
        }

        .btn-danger {
            background: #8f1f1f;
            color: #fff;
        }

        .empty-state {
            padding: 40px 20px;
            text-align: center;
            color: #666;
        }

        @media (max-width: 900px) {
            .admin-layout {
                flex-direction: column;
            }

            .sidebar {
                width: auto;
            }

            .content {
                padding: 20px;
            }

            .panel {
                overflow-x: auto;
            }
        }
    </style>
</head>
<body>
    <div class="admin-layout">
        <aside class="sidebar">
            <div class="brand">LIMELIGHT</div>
            <a href="/" class="home-link">Home</a>
            <a href="/admin/dashboard" class="active">Dashboard</a>
            <a href="/admin/products/new">Add Product</a>
        </aside>

        <main class="content">
            <h1 class="page-title">PRODUCT DASHBOARD</h1>

            <div class="panel">
                <% if (products && products.length) { %>
                    <table>
                        <thead>
                            <tr>
                                <th>Image</th>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Price (Rs.)</th>
                                <th>Rating</th>
                                <th>Stock</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% products.forEach(product => { %>
                                <tr>
                                    <td>
                                        <img class="thumb" src="<%= product.image %>" alt="<%= product.name %>">
                                    </td>
                                    <td><%= product.name %></td>
                                    <td><%= product.category %></td>
                                    <td><%= product.price %></td>
                                    <td><%= product.rating %></td>
                                    <td><%= product.stock %></td>
                                    <td>
                                        <div class="actions">
                                            <a class="btn btn-gold" href="/admin/products/edit/<%= product._id %>">Edit</a>
                                            <form class="delete-form" action="/admin/products/delete/<%= product._id %>" method="POST" data-product-name="<%= product.name %>">
                                                <button class="btn btn-danger" type="submit">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } else { %>
                    <div class="empty-state">No products available yet.</div>
                <% } %>
            </div>
        </main>
    </div>

    <script>
        document.querySelectorAll(".delete-form").forEach((form) => {
            form.addEventListener("submit", (event) => {
                const productName = form.dataset.productName || "this product";
                const confirmed = confirm(`Are you sure you want to delete ${productName}? This cannot be undone.`);
                if (!confirmed) {
                    event.preventDefault();
                }
            });
        });
    </script>
</body>
</html>