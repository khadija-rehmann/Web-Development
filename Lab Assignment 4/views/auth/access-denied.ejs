<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Access Denied - Limelight</title>
  <style>
    body { background: #f3efe5; font-family: Arial, sans-serif; margin:0; }
    .top { background: #000; color: #b38d36; padding: 12px 20px; }
    .center { display:flex; align-items:center; justify-content:center; min-height:80vh; flex-direction:column; }
    h1 { color:#b38d36; font-size:48px; letter-spacing:4px; }
    p { color:#333; margin-top:12px; }
    .btn { margin-top:18px; background:#000; color:#fff; padding:10px 16px; text-decoration:none; }
  </style>
</head>
<body>
  <!-- Shared store header. -->
  <div class="top"><h1 style="margin:0;">LIMELIGHT</h1></div>
  <!-- Message shown when the current user does not have access to the page. -->
  <div class="center">
    <h1>ACCESS DENIED</h1>
    <% if (errorMsg && errorMsg.length) { %>
      <p style="color:#b00020;font-weight:bold;"><%= errorMsg[0] %></p>
    <% } %>
    <p>You do not have permission to view this page.</p>
    <a class="btn" href="/">GO HOME</a>
  </div>
</body>
</html>
