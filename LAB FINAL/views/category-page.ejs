<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Limelight</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .category-banner { width:100%; height:400px; object-fit:cover; display:block; }
    .page-title { text-align:center; font-size:28px; letter-spacing:2px; margin:30px auto; color:#1a1a1a; }
    .product-count { text-align:center; font-size:14px; color:#666; margin-bottom:20px; }
    .products-grid { max-width:1200px; margin:0 auto; padding:0 20px; display:grid; grid-template-columns:repeat(4,1fr); gap:20px; margin-bottom:40px; }
    .product-card { background:#fff; border:1px solid #ddd; padding:15px; text-align:center; }
    .product-card img { width:100%; height:280px; object-fit:cover; }
    .product-name { font-size:14px; font-weight:bold; margin:10px 0 5px; }
    .product-price { font-size:13px; color:#666; }
    .product-price .price-old { text-decoration: line-through; color:#999; margin-right:6px; }
    .product-price .price-sale { color:#b04b4b; font-weight:bold; }
    .add-to-cart-btn { background:#000; color:#fff; width:100%; padding:10px; border:none; cursor:pointer; letter-spacing:1px; font-size:12px; margin-top:10px; }
    .no-products { text-align:center; padding:60px 20px; color:#666; }
    .view-all-btn { display:inline-block; background:#1a1a1a; color:#fff; text-decoration:none; padding:12px 30px; margin-bottom:40px; margin-left:20px; font-weight:bold; letter-spacing:1px; }
    @media (max-width:1200px) { .products-grid{ grid-template-columns:repeat(3,1fr);} }
    @media (max-width:768px) { .products-grid{ grid-template-columns:repeat(2,1fr);} .page-title{ font-size:24px;} }
    @media (max-width:480px) { .products-grid{ grid-template-columns:1fr;} .category-banner{ height:300px;} }
  </style>
</head>
<body>
  <!-- Shared top bar used by the category landing pages. -->
  <div class="top-bar">
    <div class="contact-icons">
      <img src="/images/phone.jpg" alt="Phone">
      <img src="/images/whatsapp.jpg" alt="WhatsApp">
    </div>
    <div class="top-right">
      <img src="/images/search.jpg" alt="Search">
      <h5>PKR</h5>
      <img src="/images/account.jpg" alt="Account">
      <%
        // Count total items in the session cart so the badge stays in sync.
        let cartCount = 0;
        if (currentUser && req.session && req.session.cart) {
          for (let item of req.session.cart) {
            cartCount += item.quantity;
          }
        }
      %>
      <a href="<%= currentUser ? '/cart' : '/login' %>" style="position: relative; text-decoration: none;">
        <img src="/images/cart.jpg" alt="Cart">
        <% if(cartCount > 0) { %>
          <span style="background: rgb(179, 141, 54); color: white; border-radius: 50%; padding: 2px 6px; font-size: 11px; position: absolute; top: -5px; right: -5px;">
            <%= cartCount %>
          </span>
        <% } %>
      </a>
      <% if (!currentUser) { %>
        <a href="/login" style="margin-left:10px;color:#fff;text-decoration:none;">LOGIN</a>
        <a href="/register" style="margin-left:8px;color:#fff;text-decoration:none;">REGISTER</a>
      <% } else if (currentUser.role === 'admin') { %>
        <span style="margin-left:10px;color:#fff;">Hi, <%= currentUser.name %></span>
        <a href="/profile" style="margin-left:10px;color:#fff;text-decoration:none;">MY PROFILE</a>
        <a href="/admin/dashboard" style="margin-left:10px; padding: 6px 10px; background: #b38d36; color: #1a1a1a; text-decoration: none; font-size: 12px; font-weight: bold; border-radius: 4px;">ADMIN</a>
        <a href="/logout" style="margin-left:8px;color:#b04b4b;text-decoration:none;">LOGOUT</a>
      <% } else { %>
        <span style="margin-left:10px;color:#fff;">Hi, <%= currentUser.name %></span>
        <a href="/profile" style="margin-left:10px;color:#fff;text-decoration:none;">MY PROFILE</a>
        <a href="/logout" style="margin-left:8px;color:#b04b4b;text-decoration:none;">LOGOUT</a>
      <% } %>
    </div>
  </div>

  <!-- Flash messages for category page feedback. -->
  <% if (successMsg && successMsg.length) { %>
    <div style="max-width:1200px;margin:16px auto 0;padding:12px 16px;background:#e7f7ea;color:#1f6b2d;border:1px solid #b9e3c1;border-radius:6px;">
      <%= successMsg[0] %>
    </div>
  <% } %>
  <% if (errorMsg && errorMsg.length) { %>
    <div style="max-width:1200px;margin:16px auto 0;padding:12px 16px;background:#fdecec;color:#a61d24;border:1px solid #f5b7bb;border-radius:6px;">
      <%= errorMsg[0] %>
    </div>
  <% } %>

  <!-- Shared brand header. -->
  <div class="header"><h1 class="logo">LIMELIGHT</h1></div>
  <hr color="black">

  <!-- Primary navigation. -->
  <div class="navbar" id="navbar">
    <button id="menuBtn" class="menu-btn" type="button">☰</button>
    <div class="nav-links" id="navLinks">
      <a href="/">HOME</a>
      <a href="/women">WOMEN</a>
      <a href="/men">MEN</a>
      <a href="/girls">GIRLS</a>
      <a href="/onsale-products">SALE</a>
      <a href="/products">ALL PRODUCTS</a>
    </div>
  </div>

  <!-- Category banner and product summary. -->
  <img src="<%= bannerImage %>" alt="Banner" class="category-banner">
  <div class="page-title"><%= title %></div>
  <div class="product-count">Showing <%= products.length %> product<%= products.length !== 1 ? 's' : '' %></div>

  <!-- Render the category items or an empty state. -->
  <% if (products && products.length > 0) { %>
    <div class="products-grid">
      <% products.forEach(function(product) { %>
        <div class="product-card">
          <img src="<%= product.image %>" alt="<%= product.name %>">
          <div class="product-name"><%= product.name %></div>
          <div class="product-price">
            <% if (product.isOnSale) { %>
              <span class="price-old">Rs. <%= product.originalPrice %></span>
              <span class="price-sale">Rs. <%= product.price %></span>
            <% } else { %>
              Rs. <%= product.price %>
            <% } %>
          </div>
          <form method="POST" action="/cart/add/<%= product._id %>">
            <button type="submit" class="add-to-cart-btn">ADD TO CART</button>
          </form>
        </div>
      <% }); %>
    </div>
    <div style="text-align:center;"><a href="/products" class="view-all-btn">VIEW ALL PRODUCTS</a></div>
  <% } else { %>
    <div class="no-products">
      <h2>No products in this category yet.</h2>
      <a href="/products" class="view-all-btn">BROWSE ALL PRODUCTS</a>
    </div>
  <% } %>

  <!-- Footer with support link. -->
  <div class="footer">
    <h3><b>CUSTOMER CARE</b></h3>
    <p>Order Tracking</p>
    <p>Policies</p>
    <p>FAQ's</p>
    <p><a href="/contact-us">Contact Us</a></p>
  </div>

  <script src="/js/script.js"></script>
</body>
</html>