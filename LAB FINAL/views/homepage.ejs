<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Limelight</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* Badge styling for cart count */
        .cart-count {
            background: rgb(179, 141, 54);
            color: white;
            border-radius: 50%;
            padding: 2px 6px;
            font-size: 11px;
            margin-left: 2px;
            display: inline-block;
        }
    </style>
</head>
<body>

    <!-- Top bar with contact icons and account/cart controls. -->
    <div class="top-bar">
        <div class="contact-icons">
            <img src="/images/phone.jpg" alt="Phone">
            <img src="/images/whatsapp.jpg" alt="WhatsApp">
            
        </div>

                <div class="top-right">
                        <img src="/images/search.jpg" alt="Search">
                        <h5>PKR</h5>
                        <img src="/images/account.jpg" alt="Account">
                                                <%
                                                    // Count total items in the session cart so the badge stays accurate.
                          let cartCount = 0;
                          if (currentUser && req.session && req.session.cart) {
                            for (let item of req.session.cart) {
                              cartCount += item.quantity;
                            }
                          }
                        %>
                        <a href="<%= currentUser ? '/cart' : '/login' %>" style="position: relative; text-decoration: none;">
                          <img src="/images/cart.jpg" alt="Cart">
                          <% if(cartCount > 0) { %>
                            <span style="background: rgb(179, 141, 54); color: white; border-radius: 50%; padding: 2px 6px; font-size: 11px; position: absolute; top: -5px; right: -5px;">
                              <%= cartCount %>
                            </span>
                          <% } %>
                        </a>
                        <% if (!currentUser) { %>
                            <a href="/login" style="margin-left:10px;color:#fff;text-decoration:none;">LOGIN</a>
                            <a href="/register" style="margin-left:8px;color:#fff;text-decoration:none;">REGISTER</a>
                        <% } else if (currentUser.role === 'admin') { %>
                            <span style="margin-left:10px;color:#fff;">Hi, <%= currentUser.name %></span>
                            <a href="/profile" style="margin-left:10px;color:#fff;text-decoration:none;">MY PROFILE</a>
                            <a href="/admin/dashboard" style="margin-left:10px; padding: 6px 10px; background: #b38d36; color: #1a1a1a; text-decoration: none; font-size: 12px; font-weight: bold; border-radius: 4px;">ADMIN</a>
                            <a href="/logout" style="margin-left:8px;color:#b04b4b;text-decoration:none;">LOGOUT</a>
                        <% } else { %>
                            <span style="margin-left:10px;color:#fff;">Hi, <%= currentUser.name %></span>
                            <a href="/profile" style="margin-left:10px;color:#fff;text-decoration:none;">MY PROFILE</a>
                            <a href="/logout" style="margin-left:8px;color:#b04b4b;text-decoration:none;">LOGOUT</a>
                        <% } %>
                </div>
    </div>

    <!-- Flash messages for cross-page success or error feedback. -->
    <% if (successMsg && successMsg.length) { %>
        <div style="max-width:1200px;margin:16px auto 0;padding:12px 16px;background:#e7f7ea;color:#1f6b2d;border:1px solid #b9e3c1;border-radius:6px;">
            <%= successMsg[0] %>
        </div>
    <% } %>
    <% if (errorMsg && errorMsg.length) { %>
        <div style="max-width:1200px;margin:16px auto 0;padding:12px 16px;background:#fdecec;color:#a61d24;border:1px solid #f5b7bb;border-radius:6px;">
            <%= errorMsg[0] %>
        </div>
    <% } %>

    <!-- Store logo header. -->
    <div class="header">
        <h1 class="logo">LIMELIGHT</h1>
    </div>
    <hr color="black">

    <!-- Main navigation links. -->
    <div class="navbar" id="navbar">
        <button id="menuBtn" class="menu-btn" type="button" aria-label="Toggle navigation menu" aria-controls="navLinks" aria-expanded="false">☰</button>
        <div class="nav-links" id="navLinks">
            <a href="/">HOME</a>
            <a href="/women">WOMEN</a>
            <a href="/men">MEN</a>
            <a href="/girls">GIRLS</a>
            <a href="/onsale-products">SALE</a>
            <a href="/products">ALL PRODUCTS</a>
        </div>
    </div>

    <!-- Homepage hero banner. -->
    <div class="banner-img">
        <img src="/images/banner image.png" alt="Banner" width="100%">
    </div>

    <!-- Shop by collection section. -->
    <div class="section-title">
        <h2>UNSTITCHED</h2>
    </div>

    <div class="unstitched-section">
        <a href="/category/unstitched">
            <div class="img-container">
                <img src="/images/Summer.jpg" alt="Summer">
                <p>SUMMER</p>
            </div>
        </a>

        <a href="/category/unstitched">
            <div class="img-container">
                <img src="/images/embroidered.jpg" alt="Embroidered">
                <p>EMBROIDERED</p>
            </div>
        </a>

        <a href="/category/unstitched">
            <div class="img-container">
                <img src="/images/printed.jpg" alt="Printed">
                <p>PRINTED</p>
            </div>
        </a>

        <a href="/category/unstitched">
            <div class="img-container">
                <img src="/images/velvet.jpg" alt="Velvet">
                <p>VELVET</p>
            </div>
        </a>
    </div>

    <hr>

    <div class="ready-section">
        <h2>READY TO WEAR</h2>

        <div class="ready-items">
            <a href="/category/ready-to-wear"><div class="ready-item">
                <img src="/images/Embroidered 2.jpg" alt="Embroidered">
                <p>EMBROIDERED</p>
            </div></a>

            <a href="/category/ready-to-wear"><div class="ready-item">
                <img src="/images/printed2.jpg" alt="Printed">
                <p>PRINTED</p>
            </div></a>

            <a href="/category/ready-to-wear"><div class="ready-item">
                <img src="/images/solids2.jpg" alt="Solids">
                <p>SOLIDS</p>
            </div></a>

            <a href="/category/ready-to-wear"><div class="ready-item">
                <img src="/images/co-ords.jpg" alt="Co-ords">
                <p>CO-ORDS</p>
            </div></a>

            <a href="/category/ready-to-wear"><div class="ready-item">
                <img src="/images/formals.jpg" alt="Formals">
                <p>FORMALS</p>
            </div></a>

            <a href="/category/ready-to-wear"><div class="ready-item">
                <img src="/images/kurtis.jpg" alt="Kurtis">
                <p>KURTIS</p>
            </div></a>

            <a href="/category/ready-to-wear"><div class="ready-item">
                <img src="/images/bottoms.jpg" alt="Bottoms">
                <p>BOTTOMS</p>
            </div></a>
        </div>
    </div>

    <!-- Promotional banner for fragrances. -->
    <div class="fragrances-banner">
        <h2>FRAGRANCES</h2>
        <a href="/category/fragrances"><img src="/images/fragrances.jpg" alt="Fragrances" width="100%"></a>
    </div>

    <!-- Quick links to other category landing pages. -->
    <div class="categories-section">

        <a href="/men"><div class="category-box">
            <img src="/images/men.jpg" alt="Men">
            <p>MEN</p>
        </div></a>

        <a href="/girls"><div class="category-box">
            <img src="/images/girls.jpg" alt="Girls">
            <p>GIRLS</p>
        </div></a>

        <a href="/category/bags"><div class="category-box">
            <img src="/images/bags.jpg" alt="Bags">
            <p>BAGS</p>
        </div></a>

        <a href="/category/footwear"><div class="category-box">
            <img src="/images/footwear.jpg" alt="Footwear">
            <p>FOOTWEAR</p>
        </div></a>

    </div>


    <!-- Static new-arrivals showcase. -->
    <div class="new-arrivals-section">
        <h2>NEW ARRIVALS</h2>

        <div class="products">
            <div class="product-card">
                <img src="/images/product 1.jpg" alt="Product 1">
                <h3>Silk Shirt (Pret)</h3>
                <p class="price">Rs. 3000</p>
            </div>

            <div class="product-card">
                <img src="/images/product 2.jpg" alt="Product 2">
                <h3>Embroidered (Pret)</h3>
                <p class="price">Rs. 10000</p>
            </div>

            <div class="product-card">
                <img src="/images/product 3.jpg" alt="Product 3">
                <h3>Silk Co-ord Set</h3>
                <p class="price">Rs. 75000</p>
            </div>
        </div>
    </div>

    <!-- Footer and customer-care links. -->
    <div class="footer">
        <h3><b>CUSTOMER CARE</b></h3>
        <p>Order Tracking</p>
        <p>Policies</p>
        <p>FAQ's</p>
        <p><a href="/contact-us">Contact Us</a></p>
    </div>

    <script src="/js/script.js"></script>
</body>
</html>
